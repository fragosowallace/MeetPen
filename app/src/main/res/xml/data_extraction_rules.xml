<?xml version="1.0" encoding="utf-8"?><!--
   Regras de extração de dados (API 31+).
   Exclui os SharedPreferences do backup na nuvem e da transferência entre
   dispositivos: chaves de API não devem sair do aparelho, e o conteúdo
   criptografado não é restaurável sem a master key do Keystore local.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="meetpen_prefs.xml" />
        <exclude domain="sharedpref" path="meetpen_secure_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="meetpen_prefs.xml" />
        <exclude domain="sharedpref" path="meetpen_secure_prefs.xml" />
    </device-transfer>
</data-extraction-rules>

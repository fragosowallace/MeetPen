<?xml version="1.0" encoding="utf-8"?><!--
   Regras de backup (API < 31).
   Exclui os SharedPreferences do backup na nuvem: o meetpen_prefs contém
   configurações do usuário e o meetpen_secure_prefs contém chaves de API
   criptografadas cuja master key (Keystore) não é restaurável em outro aparelho.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="meetpen_prefs.xml" />
    <exclude domain="sharedpref" path="meetpen_secure_prefs.xml" />
</full-backup-content>
